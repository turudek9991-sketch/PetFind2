    local db = AmbilDataFirebase() or {}
    local TerpilihList = {}
    for _, name in ipairs(ListSemuaPet) do if Config.Targets[name] == true then table.insert(TerpilihList, name) end end

    local orderIndex = 1
    local AntreanAutoHop = {}
    local TotalElemenGaris = 0

    for _, petName in ipairs(TerpilihList) do
        local rarity = PetMetadataRarity[petName] or "Common"
        local isHighTier = (rarity == "Mythic" or rarity == "Super")

        local Header = Instance.new("Frame", RadarScroll)
        Header.Size = UDim2.new(1, -4, 0, 16) Header.BackgroundTransparency = 1 Header.LayoutOrder = orderIndex
        orderIndex = orderIndex + 1
        TotalElemenGaris = TotalElemenGaris + 1

        local HeaderText = Instance.new("TextLabel", Header)
        HeaderText.Size = UDim2.new(1, 0, 1, 0) HeaderText.BackgroundTransparency = 1
        HeaderText.Font = Enum.Font.GothamBold HeaderText.TextSize = 9
        HeaderText.TextXAlignment = Enum.TextXAlignment.Left HeaderText.Text = petName .. " [" .. rarity .. "]"
        HeaderText.TextColor3 = isHighTier and C.RED or C.TEXT_PRI

        local serverFoundList = {}
        for jobId, srvData in pairs(db) do
            if type(srvData) == "table" and srvData[petName] then
                local info = srvData[petName]
                table.insert(serverFoundList, {
                    JobId = jobId, Players = info.CurrentPlayers or 0, MaxPlayers = info.MaxPlayers or 12, Timestamp = info.Timestamp or os.time()
                })
            end
        end

        table.sort(serverFoundList, function(a, b) return a.Timestamp < b.Timestamp end)

        if #serverFoundList == 0 then
            local NoSrv = Instance.new("Frame", RadarScroll)
            NoSrv.Size = UDim2.new(1, -4, 0, 12) NoSrv.BackgroundTransparency = 1 NoSrv.LayoutOrder = orderIndex
            orderIndex = orderIndex + 1
            TotalElemenGaris = TotalElemenGaris + 0.8

            local NoSrvText = Instance.new("TextLabel", NoSrv)
            NoSrvText.Size = UDim2.new(1, 0, 1, 0) NoSrvText.Position = UDim2.new(0, 4, 0, 0) NoSrvText.BackgroundTransparency = 1
            NoSrvText.Font = Enum.Font.GothamMedium NoSrvText.TextSize = 8 NoSrvText.TextXAlignment = Enum.TextXAlignment.Left
            NoSrvText.TextColor3 = C.TEXT_SEC NoSrvText.Text = "(no server found)"
        else
            for _, srv in ipairs(serverFoundList) do
                local Row = Instance.new("TextButton", RadarScroll)
                Row.Size = UDim2.new(1, -4, 0, 18) Row.BackgroundColor3 = C.BG_TAB Row.BorderSizePixel = 0 Row.Text = ""
                Row.LayoutOrder = orderIndex orderIndex = orderIndex + 1
                TotalElemenGaris = TotalElemenGaris + 1.1
                Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 3)
                Instance.new("UIStroke", Row).Color = C.BORDER

                local DataLbl = Instance.new("TextLabel", Row)
                DataLbl.Size = UDim2.new(0, 160, 1, 0) DataLbl.Position = UDim2.new(0, 6, 0, 0)
                DataLbl.BackgroundTransparency = 1 DataLbl.Font = Enum.Font.GothamMedium DataLbl.TextSize = 7.5 DataLbl.TextColor3 = C.TEXT_PRI
                DataLbl.Text = string.sub(srv.JobId, 1, 8) .. "   " .. srv.Players .. "/" .. srv.MaxPlayers .. "   " .. (os.time() - srv.Timestamp) .. "s"

                local ActionLbl = Instance.new("TextLabel", Row)
                ActionLbl.Size = UDim2.new(0, 60, 1, 0) ActionLbl.Position = UDim2.new(1, -66, 0, 0)
                ActionLbl.BackgroundTransparency = 1 ActionLbl.Font = Enum.Font.GothamBold ActionLbl.TextSize = 7.5
                ActionLbl.TextXAlignment = Enum.TextXAlignment.Right ActionLbl.TextColor3 = C.GREEN ActionLbl.Text = "TAP TO JOIN"

                Row.MouseButton1Click:Connect(function()
                    if srv.Players >= srv.MaxPlayers then SetStatus("Server penuh!", C.RED) return end
                    SetStatus("Teleporting manual...", C.AMBER)
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, srv.JobId, LocalPlayer)
                end)
                if srv.JobId ~= game.JobId and srv.Players < srv.MaxPlayers then table.insert(AntreanAutoHop, srv) end
            end
        end
        local Spacer = Instance.new("Frame", RadarScroll)
        Spacer.Size = UDim2.new(1, 0, 0, 3) Spacer.BackgroundTransparency = 1 Spacer.LayoutOrder = orderIndex
        orderIndex = orderIndex + 1
    end
    
    RadarScroll.CanvasSize = UDim2.new(0, 0, 0, orderIndex * 14)
    local TargetTinggiPanel = math.clamp(45 + (TotalElemenGaris * 17.5), 72, 420)
    TweenService:Create(NotifierPanel, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 270, 0, TargetTinggiPanel)}):Play()

    -- AUTO HOP LOGIC
    if Config.AutoHop and #AntreanAutoHop > 0 and not sedangMemproses then
        table.sort(AntreanAutoHop, function(a, b) return a.Timestamp < b.Timestamp end)
        local targetSrv = AntreanAutoHop[1]
        SetStatus("Auto Hop: Teleporting...", C.GREEN)
        Config.AutoHop = false SaveConfig()
        task.wait(0.5)
        TeleportService:TeleportToPlaceInstance(game.PlaceId, targetSrv.JobId, LocalPlayer)
    end
end

