task.spawn(function()

    -- [1] Bypass loading screen
    local function BypassLoading()
        local ls = workspace:FindFirstChild("LoadingScreenMenu")
        if ls then ls:Destroy() end
        pcall(function()
            local Cam = workspace.CurrentCamera
            for _, v in ipairs(Cam:GetChildren()) do
                if v:IsA("BlurEffect") or v:IsA("DepthOfFieldEffect") then v:Destroy() end
            end
            for _, v in ipairs(game:GetService("Lighting"):GetChildren()) do
                if v:IsA("BlurEffect") or v:IsA("DepthOfFieldEffect") then v:Destroy() end
            end
        end)
        pcall(function()
            local pg = LocalPlayer:FindFirstChild("PlayerGui")
            if pg then
                for _, gui in ipairs(pg:GetChildren()) do
                    local n = gui.Name:lower()
                    if string.find(n,"loading") or string.find(n,"splash") or string.find(n,"intro") then
                        gui:Destroy()
                    end
                end
            end
        end)
        local Cam = workspace.CurrentCamera
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local hum  = char:WaitForChild("Humanoid", 5)
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if hum and root then
            for i = 1, 20 do
                Cam.CameraType    = Enum.CameraType.Custom
                Cam.CameraSubject = hum
                Cam.FieldOfView   = 70
                root.Anchored     = false
                task.wait(0.03)
            end
        end
        workspace.ChildAdded:Connect(function(child)
            if child.Name == "LoadingScreenMenu" then
                task.wait(0.05); pcall(function() child:Destroy() end)
                local c2 = LocalPlayer.Character
                local h2 = c2 and c2:FindFirstChildWhichIsA("Humanoid")
                if h2 then
                    workspace.CurrentCamera.CameraType    = Enum.CameraType.Custom
                    workspace.CurrentCamera.CameraSubject = h2
                end
            end
        end)
    end

    -- [2] Optimasi render global
    local function OptimRender()
        pcall(function() settings().Rendering.QualityLevel = 1 end)
        local L = game:GetService("Lighting")
        pcall(function()
            L.GlobalShadows = false; L.FogEnd = 100000; L.Brightness = 2
        end)
        for _, efek in ipairs(L:GetChildren()) do
            if efek:IsA("BlurEffect") or efek:IsA("DepthOfFieldEffect") or
               efek:IsA("SunRaysEffect") or efek:IsA("ColorCorrectionEffect") or
               efek:IsA("BloomEffect") then
                pcall(function() efek:Destroy() end)
            end
        end
        pcall(function() workspace.Terrain.Decoration = false end)
    end

    -- [3] Hapus folder visual di workspace (AMAN — tidak menyentuh Map)
    local NUKE_WS = {
        "BirdVisuals","Birds","BlizzardBeams","GnomeVisuals","Gnomes",
        "Handles","LightningEffects","DroppedItems","Fences","Folder",
        "Middle","HolderFolders","PottedPlantVisuals","RainDrops",
        "RainSplashes","StormRainDrops","StormSplashes","Teleports",
        "Temporary","_Gardens","_PetVisualClient","NPCS","CapyBara",
    }
    local function NukeWorkspace()
        for _, nama in ipairs(NUKE_WS) do
            local f = workspace:FindFirstChild(nama)
            if f then pcall(function() f:Destroy() end) end
        end
        workspace.ChildAdded:Connect(function(child)
            for _, nama in ipairs(NUKE_WS) do
                if child.Name == nama then
                    task.wait(0.1); pcall(function() child:Destroy() end)
                end
            end
        end)
    end

    -- [4] Bersihkan Plot di Gardens (tanaman + buah)
    -- PENTING: Gardens bukan bagian dari Map, aman dihapus
    local FOLDER_BUAH = {
        "Fruits","FruitSpawnLocations","FruitVisuals",
        "PlantVisuals","GrowthVisuals","Effects","Plants",
    }
    local function IsFolderBuah(nama)
        for _, fb in ipairs(FOLDER_BUAH) do
            if nama == fb then return true end
        end
        return false
    end
    local function MatikanObj(obj)
        pcall(function()
            if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
                obj.Transparency = 1; obj.CastShadow = false
            end
            if obj:IsA("Decal") or obj:IsA("Texture") then obj.Transparency = 1 end
            if obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") or
               obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then obj.Enabled = false end
            if obj:IsA("PointLight") or obj:IsA("SurfaceLight") or obj:IsA("SpotLight") then obj.Enabled = false end
            if obj:IsA("Sound") then obj.Volume = 0 end
        end)
    end
    local function BersihkanPlot(plot)
        -- Destroy folder buah
        for _, desc in ipairs(plot:GetDescendants()) do
            if IsFolderBuah(desc.Name) then
                pcall(function() desc:Destroy() end)
            end
        end
        -- Invisible sisa
        for _, desc in ipairs(plot:GetDescendants()) do
            MatikanObj(desc)
        end
        if plot:IsA("BasePart") then
            pcall(function() plot.Transparency = 1; plot.CastShadow = false end)
        end
        -- Watch buah baru tumbuh
        plot.DescendantAdded:Connect(function(desc)
            task.wait(0.02)
            if not desc or not desc.Parent then return end
            if IsFolderBuah(desc.Name) then
                pcall(function() desc:Destroy() end); return
            end
            if desc.Parent and IsFolderBuah(desc.Parent.Name) then
                pcall(function() desc:Destroy() end); return
            end
            MatikanObj(desc)
        end)
    end
    local function HapusPlot()
        local Gardens = workspace:FindFirstChild("Gardens") or workspace:WaitForChild("Gardens", 10)
        if not Gardens then return end
        for _, child in ipairs(Gardens:GetChildren()) do
            if string.match(child.Name, "^Plot") then BersihkanPlot(child) end
        end
        Gardens.ChildAdded:Connect(function(child)
            if string.match(child.Name, "^Plot") then
                task.wait(0.2); BersihkanPlot(child)
            end
        end)
    end

    BypassLoading()
    task.wait(0.05)
    OptimRender()
    task.wait(0.05)
    NukeWorkspace()
    task.wait(0.05)
    HapusPlot()
    print("[DScripts V5] Anti Lag aktif ✔")
end)

