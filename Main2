local function MulaiBuyLoop(petModel, targetName, petKey)
    local char=LocalPlayer.Character
    local root=char and char:FindFirstChild("HumanoidRootPart")
    if not root then sedangMemproses=false return end

    local part=petModel:IsA("BasePart") and petModel
        or petModel:FindFirstChildWhichIsA("BasePart",true) or petModel.PrimaryPart
    if not part then sedangMemproses=false return end

    local prompt=petModel:FindFirstChild("BuyPrompt",true)
    if not prompt and petModel.Parent then prompt=petModel.Parent:FindFirstChild("BuyPrompt",true) end
    if not prompt then sedangMemproses=false return end

    local t0=os.clock(); local berhasil=false; local TIMEOUT=60
    pcall(function() prompt.HoldDuration=0 end)

    -- Thread pengawas: pet lenyap dari workspace = berhasil dibeli
    task.spawn(function()
        while not berhasil and (os.clock()-t0)<TIMEOUT do
            task.wait(0.01)
            if not petModel or not petModel.Parent or not petModel:IsDescendantOf(workspace) then
                berhasil=true
            end
        end
    end)

    -- Glue: karakter nempel ke pet tiap frame
    local Glue
    Glue=RunService.Heartbeat:Connect(function()
        if not petModel or not petModel.Parent or not petModel:IsDescendantOf(workspace)
        or berhasil or not Config.AutoBuy then
            if Glue then Glue:Disconnect(); Glue=nil end; return
        end
        local lp=petModel:IsA("BasePart") and petModel
            or petModel:FindFirstChildWhichIsA("BasePart",true) or petModel.PrimaryPart
        local lpr=petModel:FindFirstChild("BuyPrompt",true) or prompt
        if lp and root and lpr then
            root.CFrame=CFrame.new(lp.Position+Vector3.new(0,0.1,0.3),lp.Position)
            root.Velocity=Vector3.new(0,0,0)
            if lpr.HoldDuration~=0 then pcall(function() lpr.HoldDuration=0 end) end
        end
    end)

    -- Spam klik
    task.spawn(function()
        task.wait(0.05)
        while not berhasil and Config.AutoBuy and petModel and petModel:IsDescendantOf(workspace) do
            local lpr=petModel:FindFirstChild("BuyPrompt",true) or prompt
            if lpr then
                pcall(function()
                    if fireproximityprompt then fireproximityprompt(lpr)
                    else lpr:InputHoldBegin(); task.wait(0.01); lpr:InputHoldEnd() end
                end)
                pcall(function()
                    local VU=game:GetService("VirtualUser")
                    VU:ClickButton1(Vector2.new(
                        workspace.CurrentCamera.ViewportSize.X/2,
                        workspace.CurrentCamera.ViewportSize.Y/2
                    ))
                end)
            end
            task.wait(0.08)
        end
    end)

    while os.clock()-t0<TIMEOUT and not berhasil and Config.AutoBuy do task.wait(0.05) end
    if Glue then Glue:Disconnect(); Glue=nil end

    if berhasil then
        SetStatus("✓ "..targetName.." berhasil!", C.ACCENT, C.ACCENT)
        task.spawn(function() KirimNotifDiscord(targetName, true) end)
        PetSudahDibeli[petKey]=true
    else
        SetStatus("✕ "..targetName.." timeout", C.DANGER, C.DANGER)
        task.spawn(function() KirimNotifDiscord(targetName, false) end)
        PetSudahDibeli[petKey]=nil
    end
    sedangMemproses=false
end

-- ============================================================
-- DETECTOR
-- Anti Steal ON  = agresif (curi pet orang lain juga)
-- Anti Steal OFF = hemat (skip jika BuyPrompt disabled)
-- ============================================================
CekPetLokal = function(item)
    if not item or not item.Parent or sedangMemproses or not Config.AutoBuy then return end
    local nl=item.Name:lower(); local tv=nil
    for tName,aktif in pairs(Config.Targets) do
        if aktif and string.find(nl,tName:lower()) then tv=tName break end
    end
    if not tv then return end

    local petModel=item:IsA("Model") and item or item.Parent
    if not petModel or not petModel:IsA("Model") then return end

    local bp=petModel:FindFirstChild("BuyPrompt",true)
    if not bp then return end

    if not Config.AntiSteal and not bp.Enabled then
        SetStatus("Skip — sudah dibeli orang lain", C.TEXT_3, C.TEXT_3)
        return
    end

    local petKey=tostring(petModel).."_"..tv
    if PetSudahDibeli[petKey] then return end

    PetSudahDibeli[petKey]=true; sedangMemproses=true
    SetStatus("⬤ "..tv.." terdeteksi...", C.ACCENT, C.ACCENT)
    task.spawn(function() MulaiBuyLoop(petModel, tv, petKey) end)
end

task.spawn(function()
    local Map=workspace:WaitForChild("Map",15)
    local PF=Map and Map:WaitForChild("WildPetSpawns",15)
    if not PF then return end
    local function Hook(obj)
        if (obj:IsA("Model") or obj:IsA("BasePart")) and obj:IsDescendantOf(PF) then
            CekPetLokal(obj)
        end
    end
    for _,o in ipairs(PF:GetDescendants()) do Hook(o) end
    PF.DescendantAdded:Connect(Hook)
end)

