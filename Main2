-- ============================================================
-- FUNGSI CEK PET SPESIFIK DI SEMUA LOKASI PENYIMPANAN
-- Mencari nama pet (partial match, case-insensitive) di:
--   1. LeaderStats / PlayerData / Data (paling umum di Grow a Garden)
--   2. Folder Pets, OwnedPets, Inventory di bawah LocalPlayer
--   3. Backpack standar Roblox (jaga-jaga)
-- ============================================================
local function CekPetAdaDiStorage(namaPet)
    local namaLower = namaPet:lower()

    local function adaNama(folder)
        if not folder then return false end
        for _, v in ipairs(folder:GetChildren()) do
            if string.find(v.Name:lower(), namaLower) then
                return true
            end
        end
        -- Cek satu level lebih dalam (beberapa game nest dalam subfolder)
        for _, v in ipairs(folder:GetChildren()) do
            for _, vv in ipairs(v:GetChildren()) do
                if string.find(vv.Name:lower(), namaLower) then
                    return true
                end
            end
        end
        return false
    end

    -- 1. Cek semua folder yang mungkin menyimpan pet di LocalPlayer
    local folderNama = {
        "Pets", "OwnedPets", "Inventory", "PetInventory",
        "PlayerPets", "Collection", "Animals",
    }
    for _, fn in ipairs(folderNama) do
        -- langsung di bawah LocalPlayer
        local f = LocalPlayer:FindFirstChild(fn, true) -- recursive
        if f and adaNama(f) then return true end
    end

    -- 2. Cek PlayerData / Data / leaderstats (bisa jadi value di sana)
    local dataFolders = {
        LocalPlayer:FindFirstChild("PlayerData"),
        LocalPlayer:FindFirstChild("Data"),
        LocalPlayer:FindFirstChild("leaderstats"),
        LocalPlayer:FindFirstChild("PlayerGui") and
            LocalPlayer.PlayerGui:FindFirstChild("PetData", true) or nil,
    }
    for _, df in ipairs(dataFolders) do
        if df then
            -- Cek langsung
            if adaNama(df) then return true end
            -- Cek subfolder satu level
            for _, sub in ipairs(df:GetChildren()) do
                if adaNama(sub) then return true end
            end
        end
    end

    -- 3. Backpack standar Roblox (fallback)
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
    if bp and adaNama(bp) then return true end

    return false
end

-- ============================================================
-- SNAPSHOT JUMLAH PET SEBELUM BELI
-- Dipakai sebagai fallback jika nama tidak berubah tapi jumlah bertambah
-- ============================================================
local function HitungSemuaPetDiStorage()
    local count = 0
    local folderNama = {
        "Pets", "OwnedPets", "Inventory", "PetInventory",
        "PlayerPets", "Collection", "Animals",
    }
    for _, fn in ipairs(folderNama) do
        local f = LocalPlayer:FindFirstChild(fn, true)
        if f then
            for _ in ipairs(f:GetChildren()) do count += 1 end
        end
    end
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
    if bp then
        for _ in ipairs(bp:GetChildren()) do count += 1 end
    end
    return count
end

-- ============================================================
-- FUNGSI TEKAN BUYPROMPT (dipakai berulang di loop)
-- ============================================================
local function TekanjPetPrompt(petModel)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local part = petModel:IsA("BasePart") and petModel
        or petModel:FindFirstChildWhichIsA("BasePart", true)
        or petModel.PrimaryPart
    if not part then return end

    -- Teleport ke dekat pet
    root.CFrame = part.CFrame + Vector3.new(0, 3, 0)
    task.wait(0.05)

    -- Cari BuyPrompt
    local prompt = petModel:FindFirstChild("BuyPrompt", true)
    if not prompt and petModel.Parent then
        prompt = petModel.Parent:FindFirstChild("BuyPrompt", true)
    end
    if not prompt then return end
    if not prompt.Enabled then return end

    -- Nolkan hold duration lalu tekan
    prompt.HoldDuration = 0
    pcall(function() prompt:InputHoldBegin() end)
    task.wait(0.05)
    pcall(function() prompt:InputHoldEnd() end)

    if fireproximityprompt then
        pcall(function() fireproximityprompt(prompt) end)
    end
end

