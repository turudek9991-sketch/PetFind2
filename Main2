    -- ── Render entry ───────────────────────────────────────
    local function BuatEntryLive(order, namaPet, jobId, sisaDetik, pCur, pMax)
        local meta   = PetMetadata[namaPet] or { Rarity = "Common", Tier = 1 }
        local rarCol = RarityColor[meta.Rarity] or C.TEXT_SEC
        local isFull = (pCur >= pMax)
        local isHere = (jobId == game.JobId)

        local Card = Instance.new("Frame", LScroll)
        Card.LayoutOrder      = order
        Card.Size             = UDim2.new(1, -10, 0, 62)
        Card.BackgroundColor3 = C.BG2
        Card.BorderSizePixel  = 0
        Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 8)

        local CardStroke = Instance.new("UIStroke", Card)
        CardStroke.Color     = isFull and C.BORDER or C.BORDER
        CardStroke.Thickness = 1

        -- Accent strip kiri
        local Strip = Instance.new("Frame", Card)
        Strip.Size            = UDim2.new(0, 2, 1, -14)
        Strip.Position        = UDim2.new(0, 6, 0, 7)
        Strip.BackgroundColor3 = isFull and C.TEXT_SEC or C.ACCENT
        Strip.BorderSizePixel  = 0
        Instance.new("UICorner", Strip).CornerRadius = UDim.new(1, 0)

        -- Nama + rarity
        local NLbl = Instance.new("TextLabel", Card)
        NLbl.Size          = UDim2.new(0, 140, 0, 20)
        NLbl.Position      = UDim2.new(0, 18, 0, 8)
        NLbl.BackgroundTransparency = 1
        NLbl.Text          = namaPet
        NLbl.TextColor3    = isFull and C.TEXT_SEC or C.TEXT_PRI
        NLbl.Font          = Enum.Font.GothamBold
        NLbl.TextSize      = 12
        NLbl.TextXAlignment = Enum.TextXAlignment.Left

        local RLbl = Instance.new("TextLabel", Card)
        RLbl.Size          = UDim2.new(0, 90, 0, 20)
        RLbl.Position      = UDim2.new(1, -96, 0, 8)
        RLbl.BackgroundTransparency = 1
        RLbl.Text          = meta.Rarity
        RLbl.TextColor3    = isFull and C.TEXT_SEC or rarCol
        RLbl.Font          = Enum.Font.GothamBold
        RLbl.TextSize      = 10
        RLbl.TextXAlignment = Enum.TextXAlignment.Right

        -- Sub baris 1: job id + player
        local m = math.floor(sisaDetik / 60)
        local s = sisaDetik % 60
        local playerText = isFull and (pCur .. "/" .. pMax .. "  PENUH") or (pCur .. "/" .. pMax .. " pemain")
        local tagText    = isHere and "  [SERVER INI]" or ""

        local Sub1 = Instance.new("TextLabel", Card)
        Sub1.Size          = UDim2.new(1, -20, 0, 14)
        Sub1.Position      = UDim2.new(0, 18, 0, 28)
        Sub1.BackgroundTransparency = 1
        Sub1.Text          = string.sub(jobId, 1, 10) .. "…" .. tagText .. "   " .. playerText
        Sub1.TextColor3    = C.TEXT_SEC
        Sub1.Font          = Enum.Font.GothamMedium
        Sub1.TextSize      = 9
        Sub1.TextXAlignment = Enum.TextXAlignment.Left

        -- Sub baris 2: despawn
        local Sub2 = Instance.new("TextLabel", Card)
        Sub2.Size          = UDim2.new(1, -20, 0, 14)
        Sub2.Position      = UDim2.new(0, 18, 0, 42)
        Sub2.BackgroundTransparency = 1
        Sub2.Text          = "Despawn dalam " .. string.format("%dm %02ds", m, s)
        Sub2.TextColor3    = sisaDetik < 60 and C.DANGER or C.TEXT_SEC
        Sub2.Font          = Enum.Font.GothamMedium
        Sub2.TextSize      = 9
        Sub2.TextXAlignment = Enum.TextXAlignment.Left

        -- Klik join
        local ClickBtn = Instance.new("TextButton", Card)
        ClickBtn.Size             = UDim2.new(1, 0, 1, 0)
        ClickBtn.BackgroundTransparency = 1
        ClickBtn.Text             = ""

        ClickBtn.MouseButton1Click:Connect(function()
