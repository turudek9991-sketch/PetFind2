    PillDot.BackgroundColor3=C.TEXT_3; PillDot.BorderSizePixel=0; Corner(PillDot, 6)

    local Btn = Instance.new("TextButton", Row)
    Btn.Size=UDim2.new(1,0,1,0); Btn.BackgroundTransparency=1; Btn.Text=""

    local function Set(on)
        Row.BackgroundColor3    = on and C.ELEVATED or C.SURFACE
