-- ============================================================
-- FINAL CALIBRATED ENGINE: HYBRID INSTANT CLICKER (ANTI-FREEZE)
-- ============================================================
local function MulaiBuyLoop(petModel, targetName, petKey)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then sedangMemproses = false return end

    local part = petModel:IsA("BasePart") and petModel or petModel:FindFirstChildWhichIsA("BasePart", true) or petModel.PrimaryPart
    if not part then sedangMemproses = false return end

    local prompt = petModel:FindFirstChild("BuyPrompt", true)
    if not prompt and petModel.Parent then prompt = petModel.Parent:FindFirstChild("BuyPrompt", true) end
    if not prompt then sedangMemproses = false return end

    local waktuMulai = os.clock()
    local berhasil   = false
    local WAKTU_TIMEOUT_BARU = 60 

    -- 🌟 FORCE SET 0 DETIK DI AWAL AGAR MANUAL ATAUPUN OTOMATIS TETAP INSTAN
    pcall(function() 
        prompt.HoldDuration = 0 
    end)

    -- Thread Pengawas Status Lenyap/Terbeli dari Map Spawns
    task.spawn(function()
        while not berhasil and (os.clock() - waktuMulai) < WAKTU_TIMEOUT_BARU do
            task.wait(0.01)
            if not petModel or not petModel.Parent or not petModel:IsDescendantOf(workspace) then 
                berhasil = true 
            end
        end
    end)

    -- --------------------------------------------------------
    -- TELEPORT GLUE LOOP (KUNCI POSISI NYEFEK KE SERVER)
    -- --------------------------------------------------------
    local KoneksiTeleport
    KoneksiTeleport = RunService.Heartbeat:Connect(function()
        if not petModel or not petModel.Parent or not petModel:IsDescendantOf(workspace) or berhasil or not Config.AutoBuy then
            if KoneksiTeleport then KoneksiTeleport:Disconnect() KoneksiTeleport = nil end
            return
        end

        local livePart = petModel:IsA("BasePart") and petModel or petModel:FindFirstChildWhichIsA("BasePart", true) or petModel.PrimaryPart
        local livePrompt = petModel:FindFirstChild("BuyPrompt", true) or prompt

        if livePart and root and livePrompt then
            -- Set posisi karakter nempel rapat di pet agar validasi jarak server lolos
            local targetPosisi = livePart.Position + Vector3.new(0, 0.1, 0.3)
            root.CFrame = CFrame.new(targetPosisi, livePart.Position)
            root.Velocity = Vector3.new(0, 0, 0)
            
            -- Pastikan HoldDuration tidak ke-reset game jadi ada loading lagi
            if livePrompt.HoldDuration ~= 0 then
                pcall(function() livePrompt.HoldDuration = 0 end)
            end
        end
    end)

    -- --------------------------------------------------------
    -- THREAD SPAMMING OTOMATIS (MENCARI JALUR YANG DIRESPONS GAME)
    -- --------------------------------------------------------
    task.spawn(function()
        -- Beri jeda sangat kecil (0.05 detik) setelah teleport agar posisi sinkron di server
        task.wait(0.05) 

        while not berhasil and Config.AutoBuy and petModel and petModel:IsDescendantOf(workspace) do
            local livePrompt = petModel:FindFirstChild("BuyPrompt", true) or prompt
            if livePrompt then
                SetStatus("⚡ SPAMMING INTERACTION: " .. targetName, Color3.fromRGB(0, 255, 120))
                
                -- Tembak semua metode simulasi klik secara simultan di luar RenderStepped
                pcall(function()
                    if fireproximityprompt then
                        fireproximityprompt(livePrompt)
                    else
                        livePrompt:InputHoldBegin()
                        task.wait(0.01)
                        livePrompt:InputHoldEnd()
                    end
                end)

                -- Simulasi Klik Layar (ClickDetector fallback jika prompt berbentuk objek klik klik)
                pcall(function()
                    local VirtualUser = game:GetService("VirtualUser")
                    VirtualUser:ClickButton1(Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2))
                end)
            end
            
            -- Jeda antar-spam biar tidak membuat game freeze/lag, tapi tetap super cepat
            task.wait(0.08) 
        end
    end)

    -- Menahan thread utama sampai pet benar-benar dibeli atau timeout
    while os.clock() - waktuMulai < WAKTU_TIMEOUT_BARU and not berhasil and Config.AutoBuy do
        task.wait(0.05)
    end

    -- Bersihkan sisa koneksi tracking
    if KoneksiTeleport then KoneksiTeleport:Disconnect() KoneksiTeleport = nil end

    if berhasil then
        SetStatus("✅ " .. targetName .. " BERHASIL DIBELI!", C.GREEN)
        task.spawn(function() KirimNotifDiscord(targetName, true) end)
        PetSudahDibeli[petKey] = true
    else
        SetStatus("❌ " .. targetName .. " GAGAL / TIMEOUT", Color3.fromRGB(220, 60, 60))
        task.spawn(function() KirimNotifDiscord(targetName, false) end)
        if not Config.AntiSteal then PetSudahDibeli[petKey] = nil end
    end

    sedangMemproses = false
end
-- ============================================================
-- MAIN DETECTOR HOOKS
-- ============================================================
CekPetLokal = function(item)
    if not item or not item.Parent or sedangMemproses or not Config.AutoBuy then return end

    local namaLower   = item.Name:lower()
    local targetValid = nil
    for tName, aktif in pairs(Config.Targets) do
        if aktif and string.find(namaLower, tName:lower()) then targetValid = tName break end
    end
    if not targetValid then return end

    local petModel = item:IsA("Model") and item or item.Parent
    if not petModel or not petModel:IsA("Model") then return end

    local buyPrompt = petModel:FindFirstChild("BuyPrompt", true)
    
    if Config.AntiSteal and (not buyPrompt or not buyPrompt.Enabled) then
        return
    end

    local petKey = tostring(petModel) .. "_" .. targetValid
    if Config.AntiSteal and PetSudahDibeli[petKey] then return end

    PetSudahDibeli[petKey] = true
    sedangMemproses        = true

    SetStatus("🎯 " .. targetValid .. " Terdeteksi! Menyelaraskan Posisi...", Color3.fromRGB(100, 200, 255))
    task.spawn(function() MulaiBuyLoop(petModel, targetValid, petKey) end)
end

task.spawn(function()
    local Map = workspace:WaitForChild("Map", 15)
    local PetFolder = Map and Map:WaitForChild("WildPetSpawns", 15)
    if not PetFolder then return end

    local function HubungkanObjek(obj)
        if obj:IsA("Model") or obj:IsA("BasePart") then
            if obj:IsDescendantOf(PetFolder) then CekPetLokal(obj) end
        end
    end
    
    for _, o in ipairs(PetFolder:GetDescendants()) do HubungkanObjek(o) end
    PetFolder.DescendantAdded:Connect(HubungkanObjek)
end)

