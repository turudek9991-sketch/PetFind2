local function KirimNotifDiscord(namaPet, sukses)
    local httpFunc = HttpRequest or request or (syn and syn.request) or http_request or nil
    if not httpFunc then return end
    local judul  = sukses and "Pet Berhasil Ditangkap" or "Gagal Menangkap Pet"
    local warna  = sukses and 5763719 or 15548997
    local emoji  = sukses and "🎉" or "😢"
    local urlGbr = GambarPet[namaPet] or ""
    if #urlGbr < 10 then urlGbr = "https://i.imgur.com/AfFp7pu.png" end
    local rarity = PetRarity[namaPet] or "Common"
    local baris = {
        emoji .. " **" .. namaPet .. "** `[" .. rarity .. "]`",
        "**Status:** " .. (sukses and "✅ Masuk ke storage" or "❌ Timeout / Gagal"),
        "**Server:** `" .. tostring(game.JobId) .. "`",
        "**Waktu:** <t:" .. os.time() .. ":R>",
    }
    local payload = HttpService:JSONEncode({
        username   = "DScripts PetFinder",
        avatar_url = "https://i.imgur.com/VRRsjT7.jpeg",
        embeds = {{
            title       = judul,
            description = table.concat(baris, "\n"),
            color       = warna,
            thumbnail   = { url = urlGbr },
            footer      = { text = "DScripts PetFinder V5.0 • by dimsgti" },
            timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }}
    })
    pcall(function()
        httpFunc({ Url=DISCORD_WEBHOOK_URL, Method="POST", Headers={["Content-Type"]="application/json"}, Body=payload })
    end)
end


-- ============================================================
-- STOCK MANAGEMENT SYSTEM (FIREBASE AUTO-INCREMENT STANDALONE)
-- ============================================================
local function TambahStockFirebase(namaPet)
    pcall(function()
        local petClean = string.gsub(namaPet, "^%s*(.-)%s*$", "%1") -- Trim space
        petClean = petClean:sub(1,1):upper() .. petClean:sub(2):lower() -- Title case

        -- 1. Ambil jumlah stock lama terlebih dahulu
        local targetUrl = "https://growagardenpetfinder-default-rtdb.asia-southeast1.firebasedatabase.app/TotalStock/"..petClean..".json"
        local dataLama = game:HttpGet(targetUrl)
        local jumlahLama = 0
        
        if dataLama and dataLama ~= "null" then
            jumlahLama = tonumber(dataLama) or 0
        end
        
        -- 2. Tambah +1 dan simpan kembali
        local jumlahBaru = jumlahLama + 1
        local httpFunc = HttpRequest or request or (syn and syn.request) or http_request or nil
        if httpFunc then
            httpFunc({
                Url     = targetUrl,
                Method  = "PUT",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = game:GetService("HttpService"):JSONEncode(jumlahBaru),
            })
            print("[Stock System] Berhasil menambah stock " .. petClean .. " menjadi " .. tostring(jumlahBaru))
        end
    end)
end
_G.TambahStockFirebase = TambahStockFirebase -- Daftarkan secara global ke environment executor

