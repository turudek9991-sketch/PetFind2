local function AmbilDataFirebase()
    local httpFunc=HttpRequest or request or (syn and syn.request) or http_request or nil
    if not httpFunc then return nil end
    local ok,res=pcall(function() return httpFunc({Url=FirebaseURL.."LivePets.json",Method="GET"}) end)
    if ok and res and res.Body then
        local okD,data=pcall(function() return HttpService:JSONDecode(res.Body) end)
        if okD and type(data)=="table" then return data end
    end
    return nil
end

