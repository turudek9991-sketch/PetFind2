-- DISCORD WEBHOOK
-- Notif dikirim dengan:
--   - Thumbnail gambar pet di pojok kanan atas
--   - Info lengkap: nama, status, waktu, server
-- ============================================================
local function KirimNotifDiscord(namaPet, sukses, extraInfo)
    local httpFunc = HttpRequest or request or (syn and syn.request) or http_request or nil
    if not httpFunc then
        warn("[Webhook] Tidak ada fungsi HTTP yang tersedia!")
        return
    end

    extraInfo = extraInfo or {}

    local judul, warnaDec, emoji, statusTeks
    if sukses then
        judul      = "✅ Pet Berhasil Ditangkap!"
        warnaDec   = 5763719   -- hijau
        emoji      = "🎉"
        statusTeks = "✅ Berhasil masuk ke storage"
    else
        judul      = "❌ Gagal Menangkap Pet"
        warnaDec   = 15548997  -- merah
        emoji      = "😢"
        statusTeks = "❌ Timeout — tidak terdeteksi di storage"
    end

    local deskripsi = emoji .. " **Nama Pet:** `" .. namaPet .. "`
"
        .. "**Status:** " .. statusTeks .. "
"
        .. (extraInfo.tekan and ("**Total Tekan:** `" .. extraInfo.tekan .. "x`
") or "")
        .. (extraInfo.durasi and ("**Durasi Beli:** `" .. extraInfo.durasi .. " detik`
") or "")
        .. "**Server Job ID:** `" .. tostring(game.JobId) .. "`
"
        .. "**Waktu:** <t:" .. os.time() .. ":R>"

    local gambarURL = GetGambarPet(namaPet)

    local payload = HttpService:JSONEncode({
        username   = "Pet Finder Bot 🌱",
        avatar_url = "https://i.imgur.com/AfFp7pu.png",
        embeds = {{
            title       = judul,
            description = deskripsi,
            color       = warnaDec,
            thumbnail   = { url = gambarURL },  -- gambar pet pojok kanan atas
            footer      = { text = "Pet Finder V37 · Grow a Garden" },
            timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }}
    })

    local ok, err = pcall(function()
        httpFunc({
            Url     = DISCORD_WEBHOOK_URL,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = payload,
        })
    end)

    if not ok then
        warn("[Webhook] Gagal kirim notif Discord:", tostring(err))
    else
        print("[Webhook] Notif Discord terkirim:", namaPet, sukses and "SUKSES" or "GAGAL")
    end
end

