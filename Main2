-- FUNGSI UTAMA: LOOP BUY SAMPAI PET TERKONFIRMASI / TIMEOUT
-- Thread A : tekan BuyPrompt terus setiap INTERVAL_TEKAN detik
-- Thread B : polling storage setiap WAKTU_CEK_PET detik
--            → cari nama pet spesifik di storage
--            → fallback: jumlah total pet bertambah
-- Notif Discord dikirim HANYA setelah pet terkonfirmasi ada di storage
-- ============================================================
local function MulaiBuyLoop(petModel, targetName, petKey)
    local waktuMulai  = os.clock()
    local tekanKe     = 0
    local berhasil    = false
    local jumlahAwal  = HitungSemuaPetDiStorage()

    -- Thread B: polling storage secara paralel
    task.spawn(function()
        while not berhasil and (os.clock() - waktuMulai) < WAKTU_TIMEOUT + 3 do
            task.wait(WAKTU_CEK_PET)

            -- Prioritas 1: nama pet spesifik ketemu di storage
            if CekPetAdaDiStorage(targetName) then
                berhasil = true
                return
            end

            -- Prioritas 2: jumlah total pet bertambah (fallback)
            if HitungSemuaPetDiStorage() > jumlahAwal then
                berhasil = true
                return
            end
        end
    end)

    -- Thread A: loop tekan BuyPrompt
    while os.clock() - waktuMulai < WAKTU_TIMEOUT do
        if not petModel or not petModel.Parent then break end
        if not Config.AutoBuy then break end
        if berhasil then break end

        tekanKe = tekanKe + 1
        local sisaWaktu = math.floor(WAKTU_TIMEOUT - (os.clock() - waktuMulai))
        SetStatus(
            "🔄 Tekan #" .. tekanKe .. " · " .. targetName .. " (" .. sisaWaktu .. "s)",
            Color3.fromRGB(255, 200, 50)
        )

        TekanjPetPrompt(petModel)
        task.wait(INTERVAL_TEKAN)

        if berhasil then break end
    end

    -- Buffer agar Thread B sempat konfirmasi terakhir
    if not berhasil then task.wait(0.6) end

    -- Final check setelah loop selesai
    if not berhasil then
        if CekPetAdaDiStorage(targetName) or HitungSemuaPetDiStorage() > jumlahAwal then
            berhasil = true
        end
    end

    -- ====== HASIL ======
    if berhasil then
        local durasi = string.format("%.1f", os.clock() - waktuMulai)
        SetStatus("✅ " .. targetName .. " BERHASIL masuk! (" .. tekanKe .. "x tekan, " .. durasi .. "s)", C.GREEN)
        print("[Pet Finder V37] SUKSES:", targetName, "| Tekan:", tekanKe, "| Waktu:", durasi .. "s")

        -- Notif dikirim HANYA setelah storage terkonfirmasi
        local infoSukses = { tekan = tekanKe, durasi = durasi }
        task.spawn(function() KirimNotifDiscord(targetName, true, infoSukses) end)

        PetSudahDibeli[petKey] = true
        sedangMemproses = false
        return
    end

    -- GAGAL / TIMEOUT
    local durasi = string.format("%.1f", os.clock() - waktuMulai)
    SetStatus("❌ " .. targetName .. " TIMEOUT " .. durasi .. "s — cek manual!", Color3.fromRGB(220, 60, 60))
    print("[Pet Finder V37] GAGAL:", targetName, "| Total tekan:", tekanKe, "| Waktu:", durasi .. "s")

    local infoGagal = { tekan = tekanKe, durasi = durasi }
    task.spawn(function() KirimNotifDiscord(targetName, false, infoGagal) end)

    if not Config.AntiSteal then
        PetSudahDibeli[petKey] = nil
    end

    sedangMemproses = false
end

-- ============================================================
-- FUNGSI CEK PET (dipanggil saat pet muncul)
-- ============================================================
CekPetLokal = function(item)
    if not item or not item.Parent then return end
    if sedangMemproses then return end

    local namaLower   = item.Name:lower()
    local targetValid = nil

    for tName, aktif in pairs(Config.Targets) do
        if aktif and string.find(namaLower, tName:lower()) then
            targetValid = tName
            break
        end
    end

    if not targetValid then return end
    if not Config.AutoBuy then return end

    -- Pastikan objek adalah model pet (bukan part acak)
    local petModel = item
    if not item:IsA("Model") then
        petModel = item.Parent
        if not petModel or not petModel:IsA("Model") then return end
    end

    -- Pastikan ada BuyPrompt
    local buyPrompt = petModel:FindFirstChild("BuyPrompt", true)
    if not buyPrompt then return end

    -- ============================================================
    -- ANTI STEAL LOGIC
    -- ON  = Hemat/sopan: skip pet yang BuyPrompt-nya sudah disabled
    --       (artinya sudah dibeli orang lain duluan)
    --       Kita hanya beli pet yang BELUM ada pemiliknya
    -- OFF = Agresif: beli semua pet yang ada di area, termasuk
    --       yang sudah dibeli orang lain (selama masih di PetSpawn)
    -- ============================================================
    if Config.AntiSteal then
        -- Cek apakah BuyPrompt masih aktif (belum dibeli siapapun)
        if not buyPrompt.Enabled then
            SetStatus("Skip " .. targetValid .. " — sudah dibeli orang lain (Anti Steal ON)", C.TEXT_SEC)
            return
        end
    end
    -- Jika Anti Steal OFF: lanjut beli meskipun BuyPrompt disabled

    -- Cegah proses 2x untuk pet yang sama dalam satu sesi
    local petKey = tostring(petModel) .. "_" .. targetValid
    if PetSudahDibeli[petKey] then return end

    PetSudahDibeli[petKey] = true
    sedangMemproses        = true

    SetStatus("🎯 " .. targetValid .. " ditemukan! Memulai buy loop...", Color3.fromRGB(100, 200, 255))
    print("[Pet Finder V37] Target ditemukan:", targetValid, "| Model:", petModel.Name)

    task.spawn(function()
        MulaiBuyLoop(petModel, targetValid, petKey)
    end)
end

-- ============================================================
-- HOOKING MAP & WILD PET SPAWNS
-- ============================================================
task.spawn(function()
    local ok, Map = pcall(function() return workspace:WaitForChild("Map", 15) end)
    if not ok or not Map then
        warn("[Pet Finder V37] Map tidak ditemukan dalam 15 detik!")
        return
    end

    local ok2, PetFolder = pcall(function() return Map:WaitForChild("WildPetSpawns", 15) end)
    if not ok2 or not PetFolder then
        warn("[Pet Finder V37] WildPetSpawns tidak ditemukan dalam 15 detik!")
        return
    end

    print("[Pet Finder V37] WildPetSpawns ditemukan, mulai monitoring...")

    local function HubungkanObjek(obj)
        if obj:IsDescendantOf(PetFolder) then
            CekPetLokal(obj)
        end
    end

    -- Scan yang sudah ada
    task.defer(function()
        for _, o in ipairs(PetFolder:GetDescendants()) do
            HubungkanObjek(o)
        end
    end)

    -- Real-time detection
    PetFolder.DescendantAdded:Connect(function(newObj)
        HubungkanObjek(newObj)
    end)
end)

