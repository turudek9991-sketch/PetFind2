            StatusBar.Text = "Joining " .. string.sub(jobId,1,8) .. "…"
            LTitleLbl.Text = "Joining..."
            pcall(function()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LocalPlayer)
            end)
        end)

        ClickBtn.MouseEnter:Connect(function()
            if not isFull and not isHere then
                TweenService:Create(Card, TweenInfo.new(0.1), { BackgroundColor3 = C.BG3 }):Play()
            end
        end)
        ClickBtn.MouseLeave:Connect(function()
            TweenService:Create(Card, TweenInfo.new(0.1), { BackgroundColor3 = C.BG2 }):Play()
        end)
    end

    -- ── Refresh loop ───────────────────────────────────────
    local countdown = 5
    task.spawn(function()
        while LiveWindowRef == LSG do
            -- Countdown display
            for i = 5, 1, -1 do
                if LiveWindowRef ~= LSG then break end
                RefreshLbl.Text = "refresh " .. i .. "s"
                task.wait(1)
            end
            if LiveWindowRef ~= LSG then break end

            RefreshLbl.Text = "memuat..."

            if not HttpRequest then task.wait(5) continue end

            local ok, res = pcall(function()
                return HttpRequest({ Url = FirebaseURL .. "LivePets.json", Method = "GET" })
            end)

            if ok and res and res.Body then
                local okD, data = pcall(function() return HttpService:JSONDecode(res.Body) end)

                if okD and type(data) == "table" then
                    local entries = {}
                    local now = os.time()

                    for serverJobId, subPets in pairs(data) do
                        if type(subPets) == "table" then
                            for _, info in pairs(subPets) do
                                if type(info) == "table" and info.PetName and info.Timestamp then
                                    local sisa = PET_LIFETIME - (now - info.Timestamp)
                                    if sisa > 0 and Config.Targets[info.PetName] == true then
                                        local meta = PetMetadata[info.PetName] or { Tier = 1 }
                                        table.insert(entries, {
                                            JobId     = serverJobId,
                                            PetName   = info.PetName,
                                            Tier      = meta.Tier,
                                            SisaDetik = sisa,
                                            PCur      = info.CurrentPlayers or 1,
                                            PMax      = info.MaxPlayers or 8,
                                        })
                                    elseif sisa <= 0 then
                                        pcall(function()
                                            HttpRequest({
                                                Url    = FirebaseURL .. "LivePets/" .. serverJobId .. ".json",
                                                Method = "DELETE"
                                            })
                                        end)
                                    end
                                end
                            end
                        end
                    end

                    -- Sort tier tertinggi dulu
                    table.sort(entries, function(a, b)
                        if a.Tier ~= b.Tier then return a.Tier > b.Tier end
                        return a.SisaDetik > b.SisaDetik
                    end)

                    -- Clear list
                    for _, ch in ipairs(LScroll:GetChildren()) do
                        if ch:IsA("Frame") then ch:Destroy() end
                    end

                    if #entries == 0 then
                        LPlaceholder.Text    = "Tidak ada pet target yang ditemukan.\nPastikan bot sedang berjalan."
                        LPlaceholder.Visible = true
                    else
                        LPlaceholder.Visible = false
                        for i, entry in ipairs(entries) do
                            BuatEntryLive(i, entry.PetName, entry.JobId, entry.SisaDetik, entry.PCur, entry.PMax)
                        end
                        LScroll.CanvasSize = UDim2.new(0, 0, 0, LLayout.AbsoluteContentSize.Y + 8)
                    end

                    -- Auto Hop
                    if Config.AutoHop and #entries > 0 then
                        for _, entry in ipairs(entries) do
                            if entry.JobId ~= game.JobId and entry.PCur < entry.PMax then
                                StatusBar.Text = "Auto Hop → " .. entry.PetName .. " [" .. (PetMetadata[entry.PetName] or {Rarity="?"}).Rarity .. "]"
                                pcall(function()
                                    TeleportService:TeleportToPlaceInstance(game.PlaceId, entry.JobId, LocalPlayer)
                                end)
                                task.wait(3)
                                break
                            end
                        end
                    end
                end
            end

            RefreshLbl.Text = "refresh 5s"
        end
    end)

    return LSG
end

