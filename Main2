-- AUTO BUY HOOK: WildPetSpawns
-- ============================================================
local function CekPetLokal(item)
    if not item or not item.Parent then return end
    if not Config.AutoBuy then return end

    local namaLower = item.Name:lower()
    local petCocok  = nil

    for targetNama, aktif in pairs(Config.Targets) do
        if aktif and string.find(namaLower, targetNama:lower()) then
            petCocok = targetNama
            break
        end
    end

    if not petCocok then return end

    local targetPart = item:IsA("BasePart") and item
        or item:FindFirstChildWhichIsA("BasePart", true)
        or item.PrimaryPart

    local character = LocalPlayer.Character
    local root      = character and character:FindFirstChild("HumanoidRootPart")

    if root and targetPart then
        StatusBar.Text = "Auto Buy: " .. petCocok .. " ditemukan!"
        root.CFrame = targetPart.CFrame
        task.wait(0.08)

        local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            prompt.HoldDuration = 0
            prompt:InputHoldBegin()
            task.wait(0.01)
            prompt:InputHoldEnd()
            if fireproximityprompt then
                pcall(function() fireproximityprompt(prompt) end)
            end
        end

        task.delay(3, function()
            StatusBar.Text = "Pet Finder V31  ·  Ready"
        end)
    end
end

task.spawn(function()
    local ok, Map = pcall(function() return workspace:WaitForChild("Map", 15) end)
    if not ok or not Map then return end
    local ok2, PetFolder = pcall(function() return Map:WaitForChild("WildPetSpawns", 15) end)
    if not ok2 or not PetFolder then return end

    for _, obj in ipairs(PetFolder:GetChildren()) do task.spawn(CekPetLokal, obj) end
    PetFolder.ChildAdded:Connect(function(newItem)
        task.wait(0.03)
        task.spawn(CekPetLokal, newItem)
    end)
end)

